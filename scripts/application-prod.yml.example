# External application.yml for production / local deploy
# Copy to dist/pdf-merge-deploy/config/application.yml and edit passwords.
# Do NOT leave placeholders like <MYSQL_HOST> in the url - JDBC will treat them as hostnames and fail.

server:
  port: 8080
  tomcat:
    # Match single-file upload limit (PDF body POST to /uploads:put); avoid 413 on ~50MB files.
    max-http-post-size: 52MB

spring:
  datasource:
    url: jdbc:mysql://127.0.0.1:3306/pdf_toolkit?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
    username: root
    password: 123$%^abc
    driver-class-name: com.mysql.cj.jdbc.Driver
  data:
    # Worker uses Redis Streams (XREADGROUP). Requires Redis 5.0+ (recommend 6.2 or 7.x).
    # ERR unknown command XREADGROUP = wrong server or Redis older than 5.0 (common with old Windows Redis 3.x).
    redis:
      host: 127.0.0.1
      port: 6379
      password: 123$%^abc
      timeout: 3s

mybatis:
  mapper-locations: classpath*:mapper/**/*.xml
  configuration:
    map-underscore-to-camel-case: true
  type-aliases-package: com.company.pdfmerge.common.entity

pdfmerge:
  storage:
    root-dir: D:/data/pdf-merge
  queue:
    stream-key: stream:pdf:merge:task
    dlq-stream-key: stream:pdf:merge:task:dlq
    consumer-group: merge_worker_group
    consumer-name: worker-prod
  download:
    token-expire-minutes: 15
  limits:
    n-files: 20
    s-single-bytes: 52428800
    s-total-bytes: 209715200
  merge:
    timeout-seconds: 120
  # Optional CORS for browser (defaults: http://localhost:*, http://127.0.0.1:*).
  # cors:
  #   allowed-origin-patterns:
  #     - "https://your-frontend.example.com"
