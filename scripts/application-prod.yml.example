# External application.yml for production
# Copy this file to your target machine as application.yml,
# then fill in MySQL/Redis connection details.

spring:
  datasource:
    url: jdbc:mysql://<MYSQL_HOST>:3306/<MYSQL_DB>?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
    username: <MYSQL_USER>
    password: <MYSQL_PASSWORD>
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: none
    open-in-view: false
  data:
    redis:
      host: <REDIS_HOST>
      port: 6379
      # If your Redis has password, enable the next line.
      # password: <REDIS_PASSWORD>
      timeout: 3s

pdfmerge:
  storage:
    # Use a writable path on the production server.
    # On Windows, prefer D:/data/pdf-merge (or any absolute path).
    root-dir: D:/data/pdf-merge
  queue:
    stream-key: stream:pdf:merge:task
    dlq-stream-key: stream:pdf:merge:task:dlq
    consumer-group: merge_worker_group
    consumer-name: worker-prod
  download:
    token-expire-minutes: 15
  limits:
    n-files: 20
    s-single-bytes: 52428800
    s-total-bytes: 209715200
  merge:
    timeout-seconds: 120

